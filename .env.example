# ─── Environment ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values
# NEVER commit .env to version control

# App environment: development | staging | production
EXPO_PUBLIC_APP_ENV=development

# ─── API ──────────────────────────────────────────────────────────────────────
# .NET backend base URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# ─── Claude / Anthropic ───────────────────────────────────────────────────────
# WARNING: In production, Claude calls go through your .NET backend, NOT directly
# from the app. This key is for local development only.
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-replace-me

# ─── Swiggy Builders Club ─────────────────────────────────────────────────────
# Swiggy MCP tokens (managed by .NET backend; not exposed to client in prod)
EXPO_PUBLIC_SWIGGY_TOKEN_FOOD=replace-me
EXPO_PUBLIC_SWIGGY_TOKEN_INSTAMART=replace-me
EXPO_PUBLIC_SWIGGY_TOKEN_DINEOUT=replace-me

# ─── Push Notifications ───────────────────────────────────────────────────────
EXPO_PUBLIC_FCM_SENDER_ID=replace-me

# ─── Feature Flags ────────────────────────────────────────────────────────────
EXPO_PUBLIC_FEATURE_DINEOUT=false
EXPO_PUBLIC_FEATURE_DARK_MODE=false
EXPO_PUBLIC_USE_MOCK_DATA=true
