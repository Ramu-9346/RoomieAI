{
  "expo": {
    "name": "RoomieAI",
    "slug": "roomie-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF7F0"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.roomieai.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "RoomieAI needs camera access to scan receipts.",
        "NSPhotoLibraryUsageDescription": "RoomieAI needs photo access to save receipts.",
        "NSLocationWhenInUseUsageDescription": "RoomieAI needs your location to find restaurants near your flat.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF7F0"
      },
      "package": "com.roomieai.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C65E00",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Fraunces_500Medium.ttf",
            "./assets/fonts/Fraunces_500Medium_Italic.ttf",
            "./assets/fonts/Geist_400Regular.ttf",
            "./assets/fonts/Geist_500Medium.ttf",
            "./assets/fonts/Geist_600SemiBold.ttf",
            "./assets/fonts/GeistMono_400Regular.ttf",
            "./assets/fonts/GeistMono_500Medium.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "roomieai",
    "extra": {
      "eas": {
        "projectId": "replace-with-your-eas-project-id"
      }
    }
  }
}
