    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "immer": "^10.1.0",
    "lucide-react-native": "^1.0.0",
    "nativewind": "^4.0.36",
    "react": "19.1.0",
    "react-dom": "19.1.0",
